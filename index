                                <span class="font-semibold text-red-600">陽性：</span> 
                                鼠蹊部疼痛、卡住或複製症狀
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Craig Test -->
            <div class="flip-card" onclick="flipCard(this)">
                <div class="flip-card-inner">
                    <div class="flip-card-front">
                        <div class="mb-3"><i class="fa-solid fa-compass fa-3x opacity-90"></i></div>
                        <div class="test-name">克雷格測試</div>
                        <div class="text-blue-200 text-sm mt-1">Craig's Test</div>
                        <div class="mt-3 text-xs px-3 py-1 bg-white/20 rounded-full inline-block">股骨前傾角</div>
                    </div>
                    <div class="flip-card-back">
                        <div class="card-header flex items-center justify-between">
                            <span class="font-bold">克雷格測試 (Craig's Test)</span>
                            <i class="fa-solid fa-sync-alt text-sm cursor-pointer" onclick="event.stopImmediatePropagation(); flipCard(this.closest('.flip-card'))"></i>
                        </div>
                        <div>
                            <div class="section-title"><i class="fa-solid fa-bullseye w-4"></i> 測試目的</div>
                            <p class="detail-text">評估股骨頸前傾角（femoral anteversion）。</p>
                        </div>
                        <div class="mt-3">
                            <div class="section-title"><i class="fa-solid fa-list-ol w-4"></i> 測試步驟</div>
                            <div class="detail-text">
                                <div class="step-item" data-step="1.">患者俯臥，膝屈90°。</div>
                                <div class="step-item" data-step="2.">觸診大轉子最突出處。</div>
                                <div class="step-item" data-step="3.">測量脛骨與垂直面之角度。</div>
                            </div>
                        </div>
                        <div class="mt-auto pt-2">
                            <div class="positive">
                                <span class="font-semibold text-red-600">正常值：</span> 
                                約 8°~15° 前傾（角度過大或過小有臨床意義）
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== 考試模式 / 自測模式 ==================== -->
        <div id="quizPanel" class="hidden mt-8 max-w-3xl mx-auto">
            <div class="bg-white rounded-3xl shadow-xl border border-slate-200 overflow-hidden">
                <!-- Quiz Header -->
                <div class="bg-emerald-600 px-6 py-4 flex items-center justify-between text-white">
                    <div class="flex items-center gap-x-3">
                        <i class="fa-solid fa-graduation-cap text-2xl"></i>
                        <div>
                            <div class="font-bold text-lg">自測模式</div>
                            <div class="text-emerald-100 text-sm">主動回想，提升記憶效果</div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div id="quizProgress" class="text-sm font-medium">題目 1 / 20</div>
                        <div id="quizScore" class="text-xs text-emerald-200">正確率：0%</div>
                    </div>
                </div>

                <!-- Quiz Content -->
                <div class="p-8">
                    <!-- Question Area -->
                    <div id="quizQuestion" class="mb-6">
                        <div class="text-center">
                            <div class="text-sm text-slate-500 mb-2">請回想以下測試的相關知識</div>
                            <div id="quizTestName" class="text-3xl font-bold text-slate-800 mb-2"></div>
                            <div id="quizTestCategory" class="inline-block px-3 py-1 bg-emerald-100 text-emerald-700 text-xs font-medium rounded-full"></div>
                        </div>
                    </div>

                    <!-- Answer Area (hidden until revealed) -->
                    <div id="quizAnswer" class="hidden bg-slate-50 rounded-2xl p-6 border border-slate-200 mb-6">
                        <div class="grid grid-cols-1 gap-4 text-sm">
                            <div>
                                <div class="font-semibold text-emerald-700 mb-1 flex items-center gap-x-2">
                                    <i class="fa-solid fa-bullseye"></i> 測試目的
                                </div>
                                <div id="quizPurpose" class="text-slate-700"></div>
                            </div>
                            <div>
                                <div class="font-semibold text-emerald-700 mb-1 flex items-center gap-x-2">
                                    <i class="fa-solid fa-list-ol"></i> 測試步驟
                                </div>
                                <div id="quizSteps" class="text-slate-700 whitespace-pre-line"></div>
                            </div>
                            <div>
                                <div class="font-semibold text-emerald-700 mb-1 flex items-center gap-x-2">
                                    <i class="fa-solid fa-check-circle"></i> 陽性發現
                                </div>
                                <div id="quizPositive" class="text-slate-700"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-col gap-3">
                        <button id="revealBtn" 
                                onclick="revealAnswer()"
                                class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-2xl transition-all flex items-center justify-center gap-x-2">
                            <i class="fa-solid fa-eye"></i>
                            <span>顯示答案</span>
                        </button>

                        <div id="feedbackButtons" class="hidden grid grid-cols-2 gap-3">
                            <button onclick="markAnswer(true)" 
                                    class="py-3 bg-green-500 hover:bg-green-600 text-white font-semibold rounded-2xl transition-all flex items-center justify-center gap-x-2">
                                <i class="fa-solid fa-check"></i>
                                <span>我記住了</span>
                            </button>
                            <button onclick="markAnswer(false)" 
                                    class="py-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-2xl transition-all flex items-center justify-center gap-x-2">
                                <i class="fa-solid fa-redo"></i>
                                <span>還需要練習</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Quiz Footer -->
                <div class="bg-slate-50 px-6 py-4 flex justify-between items-center border-t">
                    <button onclick="endQuizMode()" 
                            class="px-5 py-2 text-sm text-slate-600 hover:text-slate-800 font-medium flex items-center gap-x-2">
                        <i class="fa-solid fa-times"></i>
                        <span>結束自測</span>
                    </button>
                    <button onclick="nextQuestion()" id="nextBtn"
                            class="hidden px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-2xl flex items-center gap-x-2">
                        <span>下一題</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Footer note -->
        <div class="mt-10 text-center">
            <div class="inline-flex items-center gap-x-2 text-xs text-slate-500 bg-white px-4 py-2 rounded-3xl border">
                <i class="fa-solid fa-info-circle"></i>
                <span>點擊卡片翻轉查看詳細內容 • 適合教學與臨床復習</span>
            </div>
            <p class="text-[10px] text-slate-400 mt-3">本文件僅供教育參考，非醫療診斷建議</p>
        </div>
    </div>

    <script>
        // Tailwind script
        function initializeTailwind() {
            document.documentElement.style.setProperty('--accent', '#1e40af');
        }

        // Flip single card
        function flipCard(cardElement) {
            cardElement.classList.toggle('flipped');
        }

        // Flip all cards
        function flipAllCards() {
            const cards = document.querySelectorAll('.flip-card');
            const anyFlipped = Array.from(cards).some(card => card.classList.contains('flipped'));
            
            cards.forEach(card => {
                if (anyFlipped) {
                    card.classList.remove('flipped');
                } else {
                    card.classList.add('flipped');
                }
            });
        }

        // Search / Filter cards
        function filterCards() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            const cards = document.querySelectorAll('#cardsContainer .flip-card');
            
            cards.forEach(card => {
                const frontText = card.querySelector('.flip-card-front').textContent.toLowerCase();
                const backText = card.querySelector('.flip-card-back').textContent.toLowerCase();
                
                if (frontText.includes(searchTerm) || backText.includes(searchTerm)) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Keyboard support (Escape to reset search)
        document.addEventListener('keydown', function(e) {
            if (e.key === "Escape") {
                const input = document.getElementById('searchInput');
                if (input.value !== '') {
                    input.value = '';
                    filterCards();
                } else {
                    // Flip all back if search is empty
                    document.querySelectorAll('.flip-card.flipped').forEach(c => c.classList.remove('flipped'));
                }
            }
            
            if (e.key.toLowerCase() === '?') {
                e.preventDefault();
                flipAllCards();
            }
        });

        // Initialize
        function init() {
            initializeTailwind();
            
            // Optional: Show hint on first load
            setTimeout(() => {
                const firstCard = document.querySelector('.flip-card');
                if (firstCard && !firstCard.classList.contains('flipped')) {
                    // Could add a subtle animation hint here if wanted
                }
            }, 1800);
            
            // Make sure all cards start unflipped
            console.log('%c[PT Special Tests] 翻頁卡片已載入完成', 'color:#64748b');
        }

        // ==================== 考試模式 (Quiz Mode) ====================
        let quizCards = [];
        let currentQuizIndex = 0;
        let correctCount = 0;
        let totalAnswered = 0;

        function startQuizMode() {
            // 收集所有卡片資料
            const allCards = document.querySelectorAll('.flip-card');
            quizCards = Array.from(allCards).map(card => {
                const front = card.querySelector('.flip-card-front');
                const back = card.querySelector('.flip-card-back');
                
                const nameEl = front.querySelector('.test-name');
                const categoryEl = front.querySelector('.text-blue-200');
                
                const purposeEl = back.querySelector('.detail-text');
                const stepsContainer = back.querySelectorAll('.step-item');
                const positiveEl = back.querySelector('.positive');
                
                let stepsText = '';
                stepsContainer.forEach(item => {
                    stepsText += item.textContent.trim() + '\n';
                });

                return {
                    element: card,
                    name: nameEl ? nameEl.textContent.trim() : '未知測試',
                    category: categoryEl ? categoryEl.textContent.trim() : '',
                    purpose: purposeEl ? purposeEl.textContent.trim() : '',
                    steps: stepsText.trim(),
                    positive: positiveEl ? positiveEl.textContent.trim() : ''
                };
            });

            // 洗牌
            quizCards = quizCards.sort(() => Math.random() - 0.5);
            currentQuizIndex = 0;
            correctCount = 0;
            totalAnswered = 0;

            // 切換畫面
            document.getElementById('cardsContainer').classList.add('hidden');
            document.getElementById('quizPanel').classList.remove('hidden');
            
            showCurrentQuestion();
        }

        function showCurrentQuestion() {
            if (currentQuizIndex >= quizCards.length) {
                endQuizMode();
                return;
            }

            const current = quizCards[currentQuizIndex];
            
            // 更新題目
            document.getElementById('quizTestName').textContent = current.name;
            document.getElementById('quizTestCategory').textContent = current.category;
            
            // 重置答案區
            document.getElementById('quizAnswer').classList.add('hidden');
            document.getElementById('revealBtn').classList.remove('hidden');
            document.getElementById('feedbackButtons').classList.add('hidden');
            document.getElementById('nextBtn').classList.add('hidden');

            // 更新進度
            document.getElementById('quizProgress').textContent = `題目 ${currentQuizIndex + 1} / ${quizCards.length}`;
            const percentage = totalAnswered > 0 ? Math.round((correctCount / totalAnswered) * 100) : 0;
            document.getElementById('quizScore').textContent = `正確率：${percentage}%`;
        }

        function revealAnswer() {
            const current = quizCards[currentQuizIndex];
            
            document.getElementById('quizPurpose').textContent = current.purpose;
            document.getElementById('quizSteps').innerHTML = current.steps.replace(/\n/g, '<br>');
            document.getElementById('quizPositive').textContent = current.positive;
            
            document.getElementById('quizAnswer').classList.remove('hidden');
            document.getElementById('revealBtn').classList.add('hidden');
            document.getElementById('feedbackButtons').classList.remove('hidden');
        }

        function markAnswer(isCorrect) {
            totalAnswered++;
            if (isCorrect) correctCount++;

            document.getElementById('feedbackButtons').classList.add('hidden');
            document.getElementById('nextBtn').classList.remove('hidden');
            
            // 更新分數顯示
            const percentage = Math.round((correctCount / totalAnswered) * 100);
            document.getElementById('quizScore').textContent = `正確率：${percentage}%`;
        }

        function nextQuestion() {
            currentQuizIndex++;
            showCurrentQuestion();
        }

        function endQuizMode() {
            document.getElementById('quizPanel').classList.add('hidden');
            document.getElementById('cardsContainer').classList.remove('hidden');
            
            // 顯示結果
            if (totalAnswered > 0) {
                const percentage = Math.round((correctCount / totalAnswered) * 100);
                alert(`自測完成！\n\n作答 ${totalAnswered} 題\n答對 ${correctCount} 題\n正確率：${percentage}%`);
            }
            
            // 重置
            quizCards = [];
            currentQuizIndex = 0;
            correctCount = 0;
            totalAnswered = 0;
        }

        window.onload = init;
    </script>
</body>
</html>
